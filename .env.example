ATLASSIAN_BASE_URL=https://momosunshine5.atlassian.net
ATLASSIAN_EMAIL=you@example.com
ATLASSIAN_API_TOKEN=replace-with-api-token
CONFLUENCE_SPACE_KEY=SOFTWAREEN
JIRA_PROJECT_KEY=KAN

# Alibaba Cloud Model Studio (DashScope), OpenAI-compatible endpoint.
# EMBEDDING_API_KEY/EMBEDDING_BASE_URL are also used for chat completions (CHAT_MODEL).
EMBEDDING_API_KEY=replace-with-dashscope-api-key
EMBEDDING_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIMENSIONS=1024
CHAT_MODEL=qwen-plus
CHAT_MODELS=qwen-plus,qwen-max,qwen3-max
VISION_MODEL=qwen-vl-plus

# Storage provider:
# - local: local development only
# - s3/minio: private cloud object storage such as MinIO or Ceph RGW
# - supabase: public cloud Supabase Storage
FILE_STORAGE_PROVIDER=local
UPLOAD_STORAGE_DIR=data/uploads

# Private cloud option: S3-compatible object storage, e.g. MinIO.
# FILE_STORAGE_PROVIDER=s3
# S3_ENDPOINT_URL=http://minio:9000
# S3_REGION=us-east-1
# S3_BUCKET=supportagent-uploads
# S3_ACCESS_KEY_ID=supportagent
# S3_SECRET_ACCESS_KEY=replace-with-private-cloud-secret

# Public cloud option: store uploads in Supabase Storage instead of local disk.
# FILE_STORAGE_PROVIDER=supabase
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
# SUPABASE_STORAGE_BUCKET=supportagent-uploads

DATABASE_URL=postgresql://supportagent:supportagent@localhost:5433/supportagent

# Local session authentication. Set AUTH_COOKIE_SECURE=true behind HTTPS.
AUTH_SESSION_TTL_DAYS=14
AUTH_COOKIE_SECURE=false

# Optional SMTP for password reset emails. If omitted, forgot-password returns
# a demo reset link in the API response instead of sending email.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true

# Microsoft Graph OAuth for personal Microsoft accounts.
# Register a Microsoft app and add this redirect URI:
# http://localhost:8000/auth/microsoft/callback
MICROSOFT_CLIENT_ID=replace-with-application-client-id
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=consumers
MICROSOFT_REDIRECT_URI=http://localhost:8000/auth/microsoft/callback
MICROSOFT_SCOPES=offline_access User.Read Calendars.ReadWrite Files.ReadWrite
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_BACKEND_API_URL=http://localhost:8000

# Production (Supabase): use the transaction pooler (port 6543) for serverless
# deployments like Vercel, not the direct connection (port 5432).
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Private cloud production: use an internal PostgreSQL/pgvector service.
# DATABASE_URL=postgresql://supportagent:replace-with-password@postgres:5432/supportagent
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_BASE_URL=https://cloud.langfuse.com
