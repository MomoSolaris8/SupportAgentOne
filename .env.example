ATLASSIAN_BASE_URL=https://momosunshine5.atlassian.net
ATLASSIAN_EMAIL=you@example.com
ATLASSIAN_API_TOKEN=replace-with-api-token
CONFLUENCE_SPACE_KEY=SOFTWAREEN
JIRA_PROJECT_KEY=KAN

# Alibaba Cloud Model Studio (DashScope), OpenAI-compatible endpoint.
# EMBEDDING_API_KEY/EMBEDDING_BASE_URL are also used for chat completions (CHAT_MODEL).
EMBEDDING_API_KEY=replace-with-dashscope-api-key
EMBEDDING_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIMENSIONS=1024
CHAT_MODEL=qwen3-max

DATABASE_URL=postgresql://supportagent:supportagent@localhost:5433/supportagent

# Production (Supabase): use the transaction pooler (port 6543) for serverless
# deployments like Vercel, not the direct connection (port 5432).
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com